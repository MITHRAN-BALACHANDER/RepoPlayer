# RepoScope — Environment Configuration
# Copy this file to .env and fill in the values you need.
# .env is gitignored and never committed.

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose one: gemini | ollama | anthropic | openai
# Default: gemini  
LLM_PROVIDER=gemini

# ── Gemini (free) ─────────────────────────────────────────────────────────────
# Get a free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model override — default gemini-2.5-flash works well for most repos
# GEMINI_MODEL=gemini-2.5-flash

# ── Ollama (local, no key needed) ─────────────────────────────────────────────
# Install: https://ollama.com  |  Then: ollama pull llama3.2
# OLLAMA_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434

# ── Anthropic Claude ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── OpenAI ────────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── GitHub (optional) ─────────────────────────────────────────────────────────
# Without a token: 60 API requests/hour (fine for occasional use)
# With a token:  5,000 API requests/hour
# Generate at: https://github.com/settings/tokens  (no scopes needed for public repos)
# GITHUB_TOKEN=ghp_...
